@startuml As is
title BPMN As Is — текущий процесс обслуживания (с ошибками)

|Гость|
start
:Заходит в кофейню;
:Делает заказ;

|Кассир|
:Принимает заказ;
:Передаёт заказ устно\nБариста и Повару;

fork
  |Бариста|
  if (Бариста запомнил заказ?) then (нет)
    :Забывает про заказ;
    :Гость ждёт, недоволен;
    if (Гость жалуется?) then (да)
      :Кассир напоминает;
    else (нет)
      :Гость пишет плохой отзыв;
    endif
    :Готовит напиток с задержкой;
  else (да)
  endif

  if (Бариста обучен?) then (нет)
    :Не помнит пропорции;
    :Готовит "как получится";
    :Гость недоволен качеством;
    :Требует возврат денег;
    :Пишет негативный отзыв;
    :Уходит;
    stop
  else (да)
  endif

  if (Ингредиенты в наличии?) then (нет)
    :Солёной карамели нет;
    :Сообщает кассиру;
    |Кассир|
    :Сообщает гостю;
    if (Гость согласен на замену?) then (нет)
      :Возвращает деньги;
      :Гость уходит недовольным;
      stop
    else (да)
      :Гость выбирает другой сироп;
    endif
  else (да)
  endif

  :Готовит капучино;
  :Отдаёт напиток гостю;

fork again
  |Повар|
  if (Повар запомнил заказ?) then (нет)
    :Забывает про заказ;
    :Гость ждёт очень долго;
    if (Гость просит вернуть деньги?) then (да)
      |Кассир|
      :Возвращает деньги;
      :Гость уходит;
      stop
    else (нет)
      :Гость ждёт, но недоволен;
      :Кассир напоминает;
    endif
    :Готовит блюдо с задержкой;
  else (да)
  endif

  if (Повар обучен?) then (нет)
    :Не помнит техкарту;
    :Готовит "как умеет";
    :Каша получается невкусной;
    :Гость недоволен;
    :Пишет негативный отзыв;
    :Уходит недовольным;
    stop
  else (да)
  endif

  if (Ингредиенты в наличии?) then (нет)
    :Рис закончился;
    :Сообщает кассиру;
    |Кассир|
    :Сообщает гостю;
    if (Гость согласен на замену?) then (нет)
      :Возвращает деньги;
      :Гость уходит недовольным;
      stop
    else (да)
      :Гость выбирает другое блюдо;
    endif
  else (да)
  endif

  :Готовит рисовую кашу;
  :Передаёт блюдо Бариста;

end fork

|Бариста|
:Забирает напиток и блюдо;
:Относит заказ гостю;

|Гость|
if (Всё хорошо?) then (нет)
  :Недоволен качеством или ожиданием;
  :Пишет негативный отзыв;
  :Уходит;
else (да)
  :Наслаждается едой;
  :Пишет положительный отзыв;
  :Уходит довольным;
endif
stop
@enduml